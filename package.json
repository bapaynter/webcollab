{
  "name": "canvas",
  "version": "1.0.0",
  "description": "A public website where anyone can suggest small, LLM-mediated changes via a chat widget. Approved edits are broadcast to all connected visitors in real time and applied in place.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "isomorphic-dompurify": "^3.17.0",
    "parse5": "^8.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
