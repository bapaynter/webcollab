# OpenRouter auth (required)
OPENROUTER_API_KEY=

# LLM models
VALIDATOR_MODEL=anthropic/claude-3-haiku
EXECUTOR_MODEL=anthropic/claude-3.5-sonnet

# 32+ random bytes, hex. NEVER rotate (would orphan all rate limits).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=

# Per-IP cooldown
COOLDOWN_MINUTES=60
RATE_LIMIT_ENABLED=false

# Edit policy limits
MAX_EDIT_DELTA=20
MAX_PAGE_DEPTH=4

# Server
PORT=3131
HOST=127.0.0.1
LOG_LEVEL=info

# Data dir for canvas.db (also used by rollback script)
CANVAS_DATA_DIR=./data

# Optional: protect POST /api/rollback with Bearer auth.
# Leave empty to disable rollback auth.
CANVAS_ADMIN_TOKEN=
